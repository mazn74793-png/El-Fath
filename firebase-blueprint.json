{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a store clerk, manager, or pharmacist",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth unique ID" },
        "displayName": { "type": "string", "description": "Full name of the system user" },
        "email": { "type": "string", "description": "User business email" },
        "role": { "type": "string", "enum": ["clerk", "manager", "admin"], "description": "Access level in the system" },
        "shopName": { "type": "string", "description": "Name of the store branch" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["uid", "displayName", "email", "role", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Inventory product item for retail store or pharmacy",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique product barcode or autogenerated ID" },
        "name": { "type": "string", "description": "Product brand/generic description" },
        "barcode": { "type": "string", "description": "Universal product UPC/EAN or medical barcode" },
        "category": { "type": "string", "description": "Product department (e.g., Antibiotics, Cosmetics, Beverages)" },
        "costPrice": { "type": "number", "description": "Wholesale purchasing price per unit" },
        "sellingPrice": { "type": "number", "description": "Retail price before taxes and discounts" },
        "quantity": { "type": "number", "description": "Current on-hand physical stock quantity" },
        "safetyStock": { "type": "number", "description": "The threshold limit below which a restock alert triggers" },
        "expirationDate": { "type": "string", "format": "date", "description": "Optional expiration date" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last inventory sync timestamp" },
        "updatedBy": { "type": "string", "description": "UID of the user who modified this item" },
        "shopId": { "type": "string", "description": "Associated shop branch ID" }
      },
      "required": ["id", "name", "barcode", "costPrice", "sellingPrice", "quantity", "safetyStock", "updatedAt", "shopId"]
    },
    "SalesOrder": {
      "title": "SalesOrder",
      "description": "Customer purchase transaction record",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ticket transaction ID" },
        "cashierId": { "type": "string", "description": "UID of the cashier who logged the sale" },
        "cashierName": { "type": "string", "description": "Display name of the cashier" },
        "shiftId": { "type": "string", "description": "Unique active shift ID during sales order execution" },
        "items": { "type": "array", "description": "List of purchase line items" },
        "subtotal": { "type": "number", "description": "Sum of inventory item prices before tax/disc" },
        "discount": { "type": "number", "description": "Operational flat discount applied to checkout" },
        "tax": { "type": "number", "description": "Applied VAT/Sales taxes" },
        "total": { "type": "number", "description": "Final paid transactional invoice value" },
        "paymentMethod": { "type": "string", "enum": ["cash", "card"], "description": "Payment mode" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Server timestamp of sales order confirmation" },
        "shopId": { "type": "string", "description": "Associated shop branch ID" }
      },
      "required": ["id", "cashierId", "shiftId", "items", "subtotal", "total", "paymentMethod", "createdAt", "shopId"]
    },
    "Shift": {
      "title": "Shift",
      "description": "Cashier daily shift log (الوردية) for security audit",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique shift register log ID" },
        "cashierId": { "type": "string", "description": "UID of the cashier in control of the drawer" },
        "cashierName": { "type": "string", "description": "Display name of the cashier" },
        "openedAt": { "type": "string", "format": "date-time", "description": "Timestamp of shift start" },
        "closedAt": { "type": "string", "format": "date-time", "description": "Timestamp of shift termination" },
        "openingCash": { "type": "number", "description": "Initial physical cash inside drawer (float balance)" },
        "cashSales": { "type": "number", "description": "Sum total of cash payments recorded during shift" },
        "cardSales": { "type": "number", "description": "Sum total of credit card transactions checked out" },
        "expectedCash": { "type": "number", "description": "Calculated expected final cash" },
        "actualCash": { "type": "number", "description": "Clerk raw physical cash count on close" },
        "discrepancy": { "type": "number", "description": "Variance between expected cash tally and raw counted cash" },
        "status": { "type": "string", "enum": ["open", "closed"], "description": "State of shift registry drawer" },
        "shopId": { "type": "string", "description": "Associated shop branch ID" }
      },
      "required": ["id", "cashierId", "cashierName", "openedAt", "openingCash", "status", "shopId"]
    },
    "RepairOrder": {
      "title": "RepairOrder",
      "description": "Customer device repair assignment details",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique database ID of repair job" },
        "clientName": { "type": "string", "description": "Name of client owner" },
        "clientPhone": { "type": "string", "description": "Phone number of client" },
        "deviceName": { "type": "string", "description": "Name of appliance device" },
        "problemDetails": { "type": "string", "description": "Diagnostic and hardware concerns" },
        "partsNeeded": { "type": "string", "description": "Materials and segments to be ordered/changed" },
        "cost": { "type": "number", "description": "Combined cost price of fixing device" },
        "deposit": { "type": "number", "description": "Initial paid down-payment" },
        "isDepositPaid": { "type": "boolean", "description": "Whether deposit billing is clear" },
        "status": { "type": "string", "enum": ["pending", "in_progress", "ready", "delivered"], "description": "Current status" },
        "notes": { "type": "string", "description": "Free notes reference" },
        "receivedDate": { "type": "string", "format": "date", "description": "Date received" },
        "expectedDeliveryDate": { "type": "string", "format": "date", "description": "Target checkout date" },
        "shopId": { "type": "string", "description": "Associated shop branch ID" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Timestamp update" }
      },
      "required": ["id", "clientName", "clientPhone", "deviceName", "status", "shopId", "updatedAt"]
    },
    "Shop": {
      "title": "Shop",
      "description": "Store branch metadata settings",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique shop identifier" },
        "name": { "type": "string", "description": "Official branch naming" },
        "type": { "type": "string", "description": "Store domain category" },
        "currency": { "type": "string", "description": "Local base currency" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp created" }
      },
      "required": ["id", "name", "type", "currency", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Stores user security profiles."
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Master list containing stocks, barcodes, and values."
    },
    "sales_orders/{orderId}": {
      "schema": "SalesOrder",
      "description": "Completed transaction checkout invoices."
    },
    "shifts/{shiftId}": {
      "schema": "Shift",
      "description": "Registers safe drawer counts and durations."
    },
    "repairs/{repairId}": {
      "schema": "RepairOrder",
      "description": "Tracks maintenance request logs, costs, and customer lines."
    },
    "shops/{shopId}": {
      "schema": "Shop",
      "description": "Configurations for multiple branch instances."
    }
  }
}
