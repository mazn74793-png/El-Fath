rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. DEFAULT DENY CATCH-ALL
    match /{document=**} {
      allow read, write: if false;
    }

    // PRODUCTS
    match /products/{productId} {
      allow read, write: if true;
    }

    // SALES ORDERS
    match /sales_orders/{orderId} {
      allow read, write: if true;
    }

    // SHIFT REGISTER LOGS
    match /shifts/{shiftId} {
      allow read, write: if true;
    }

    // REPAIRS AND CLIENT MANAGEMENT
    match /repairs/{repairId} {
      allow read, write: if true;
    }

    // SYSTEM DEVICES TRACKER
    match /devices/{deviceId} {
      allow read, write: if true;
    }

    // MULTI-SHOP BRANCH SETTINGS
    match /shops/{shopId} {
      allow read, write: if true;
    }

    // BACKWARD COMPATIBLE USERS
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
